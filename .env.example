# =============================================================================
# .env.example — AI PR Review Agent
#
# USAGE:
#   cp .env.example .env
#   Fill in every value marked <REPLACE_ME> with your real credentials.
#   Never commit .env — it is in .gitignore.
#
# CLOUD SERVICES (recommended):
#   Postgres  -> Neon (neon.tech)           free tier, serverless
#   Redis     -> Railway Plugin             auto-injected as REDIS_URL
#   Qdrant    -> Qdrant Cloud (cloud.qdrant.io)  free 1-cluster tier
#   LLM       -> OpenAI (platform.openai.com)
#
# LOCAL DEV (no cloud accounts):
#   docker-compose -f docker-compose.dev.yml up --build
# =============================================================================

# =============================================================================
# GitHub Integration
# =============================================================================

# The secret used to sign every webhook delivery (X-Hub-Signature-256 header).
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=<REPLACE_ME>

# Personal Access Token (classic) or fine-grained PAT.
# Scopes needed: contents:read, pull_requests:read+write
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=<REPLACE_ME>

# GitHub REST API base URL. For GHE: https://github.mycompany.com/api/v3
GITHUB_API_BASE_URL=https://api.github.com

# =============================================================================
# Database — PostgreSQL (Neon Cloud)
# =============================================================================

# asyncpg requires ssl=require (NOT sslmode=require — that is psycopg2 syntax).
# Neon connection string from: neon.tech -> project -> connection details
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>.neon.tech/<dbname>?ssl=require

# =============================================================================
# Redis — Job Queue (Railway Plugin or local)
# =============================================================================

# Railway auto-injects REDIS_URL when you add the Redis plugin.
# For local dev this is set in docker-compose.dev.yml.
REDIS_URL=redis://localhost:6379

# =============================================================================
# Qdrant — Vector Store / RAG Context (Qdrant Cloud)
# =============================================================================

# Qdrant Cloud cluster endpoint (includes port 6333).
# Find at: cloud.qdrant.io -> cluster -> endpoint
QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io:6333

# Qdrant Cloud API key (JWT).
# Find at: cloud.qdrant.io -> cluster -> API keys
QDRANT_API_KEY=<REPLACE_ME>

# Name of the collection that stores codebase embeddings.
QDRANT_COLLECTION_NAME=codebase_embeddings

# =============================================================================
# LLM Providers
# =============================================================================

# OpenAI API key — used for all agents (security, quality, test, docs).
# Get at: platform.openai.com/api-keys
OPENAI_API_KEY=<REPLACE_ME>

# Anthropic API key — optional, only if SECURITY_PROVIDER=anthropic.
ANTHROPIC_API_KEY=<REPLACE_ME>

# Embedding model for RAG ingestion.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Which provider + model to use for each agent role.
# SECURITY_PROVIDER=openai is the verified working config (Anthropic key needs
# separate verification if you switch).
SECURITY_PROVIDER=openai
SECURITY_MODEL=gpt-4o

# =============================================================================
# Application Settings
# =============================================================================

# Environment tag — used in logs and health endpoint.
APP_ENV=production

LOG_LEVEL=INFO

# Maximum number of PR review jobs running concurrently in the worker.
MAX_CONCURRENT_REVIEWS=5

# Minimum confidence score for auto-approval (0.0 - 1.0).
CONFIDENCE_THRESHOLD=0.85

# Seconds before a review workflow is killed and marked timed_out.
WORKFLOW_TIMEOUT_SECONDS=300

# API key for the internal REST endpoints (/api/v1/*).
# Used by the demo script and any external caller.
# Generate: openssl rand -hex 32
API_KEY=<REPLACE_ME>